{
  "name": "vox-engine",
  "version": "0.2.0",
  "description": "Lightweight experimental reactive JavaScript library",
  "type": "module",
  "main": "./dist/vox.cjs",
  "module": "./dist/vox.esm.js",
  "exports": {
    ".": {
      "import": "./dist/vox.esm.js",
      "require": "./dist/vox.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run test:run && rm -rf dist && webpack",
    "build:dev": "npm run test:run && rm -rf dist && VOX_DEBUG=true npm run build",
    "watch": "webpack --watch --mode development",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4"
  }
}
